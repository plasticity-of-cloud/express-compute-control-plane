{
  "languages": {
    "java": {
      "name": "jdtls",
      "command": "/home/ubuntu/programs/jdt-ts/bin/jdtls",
      "args": [
        "-data",
        "/home/ubuntu/.local/share/jdtls/workspace"
      ],
      "file_extensions": ["java"],
      "project_patterns": [
        "pom.xml",
        "build.gradle",
        "build.gradle.kts",
        ".project"
      ],
      "exclude_patterns": [
        "**/target/**",
        "**/build/**",
        "**/.gradle/**"
      ],
      "multi_workspace": false,
      "request_timeout_secs": 120
    }
  }
}
